# PostgreSQL — соответствует docker-compose.yml (порт хоста 5433!)
DATABASE_URL="postgresql://cards:cards_dev_password@localhost:5433/cards?schema=public"

# JWT — сгенерируй свой секрет, например: openssl rand -base64 32
JWT_SECRET="change_me"

# Google OAuth — console.cloud.google.com (оставь пустым, если не используешь)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/google/callback

# Фронтенд — для ссылок в письмах и OAuth-редиректов
FRONTEND_URL=http://localhost:3000

# SMTP — в dev это Mailpit из docker-compose; в проде реальный релей
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM="LangCards <noreply@langcards.local>"
